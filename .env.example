# Google Gemini API Key — aistudio.google.com/apikey (ücretsiz)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot Token — @BotFather'dan alınır
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Telegram Chat ID — mesaj gönderilecek kullanıcı veya grup ID'si
# Kendi ID'nizi öğrenmek için: @userinfobot'a /start yazın
TELEGRAM_CHAT_ID=123456789
