# Google Gemini API Key — aistudio.google.com/apikey (ücretsiz)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot Token — @BotFather'dan alınır
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Telegram Chat ID — mesaj gönderilecek kullanıcı veya grup ID'si
# Kendi ID'nizi öğrenmek için: @userinfobot'a /start yazın
TELEGRAM_CHAT_ID=123456789

# (Opsiyonel) Admin Chat ID — sistem uyarıları buraya düşer.
# Belirtilmezse TELEGRAM_CHAT_ID'ye düşer.
# TELEGRAM_ADMIN_CHAT_ID=123456789

# Bot komutlarını çalıştırabilecek chat_id'ler (virgülle ayrılmış).
# Tanımlı değilse tüm gönderenler kabul edilir (DEV MODU — canlıda mutlaka set edin).
# TELEGRAM_ADMIN_IDS=123456789,987654321

# İç IP adresini Pi durumu mesajlarında göster. Abone sistemine geçince
# müşterilere görünmemesi için varsayılan kapalı. Kişisel kullanımda "1" yapın.
# SHOW_INTERNAL_IP=1
